<Window x:Class="Complex_Practica.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Complex_Practica"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        WindowState="Maximized" 
        Title="MainWindow"
        MinHeight="1020" 
        MinWidth="1920"
        FontSize="20">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="63.6"/>
            <RowDefinition Height="Auto" MinHeight="52"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="path"
                 Grid.Row="0" Grid.Column="0"
                 materialDesign:HintAssist.Hint="Путь"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 Margin="175,0,10,10" Cursor="Hand"/>

        <Button x:Name="Open_file" Grid.Column="0"
            Content="Открыть файл"
            HorizontalAlignment="Left"   
            VerticalAlignment="Center"
                FontSize="20"
            Style="{StaticResource MaterialDesignFlatDarkBgButton}"
            Click="Open_file_Click" Width="170" Height="43"/>

        <Button Grid.Row="0" Grid.Column="2"
                x:Name="ShowInstructionsButton"
                Content="?"
                Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                Width="42"
                Height="42"
                Margin="0,0,10,10"
                Click="ShowInstructions_Click"
                FontSize="24"
                FontWeight="Bold"
                ToolTip="Инструкция по применению"
                VerticalAlignment="Center"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" Margin="0,0,0,10"
                    x:Name="PanelBox">
            <CheckBox Style="{StaticResource MaterialDesignDarkCheckBox}"
                  x:Name="Kamaldinov"
                  Content="Определить последовательность цифр"
                  ToolTip="Определить последовательность цифр"
                  Margin="0,0,10,0"/>

            <CheckBox Style="{StaticResource MaterialDesignDarkCheckBox}"
                  x:Name="Krasnukov"
                  Content="Номера минимальных и максимальных цифр"
                  ToolTip="Номера минимальных и максимальных цифр"
                  Margin="0,0,10,0"/>

            <CheckBox Style="{StaticResource MaterialDesignDarkCheckBox}"
                  x:Name="Proskuryakov"
                  Content="Является ли произведение цифр четным"
                  ToolTip="Является ли произведение цифр четным"
                  Margin="0,0,10,0"/>

            <CheckBox Style="{StaticResource MaterialDesignDarkCheckBox}"
                  x:Name="Chernyakov"
                  Content="Является ли число палиндромом"
                  ToolTip="Является ли число палиндромом"
                  Margin="0,0,10,0"/>

            <CheckBox Style="{StaticResource MaterialDesignDarkCheckBox}"
                  x:Name="Poryvaev"
                  Content="Определить четность или нечетность цифр"
                  ToolTip="Определить четность или нечетность цифр"
                  Margin="0,0,10,0"/>

            <Button x:Name="to_know"
                    Content="Определить"
                    Height="42"
                    Width="148"
                    FontSize="20"
                    VerticalAlignment="Center"
                    Click="to_know_Click"
                    Style="{StaticResource MaterialDesignFlatDarkBgButton}"/>
        </StackPanel>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="TextFile"
                     materialDesign:HintAssist.Hint="Исходный текст"
                     Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}"/>

            <TextBox Grid.Column="2"
                     x:Name="TextInputFile"
                     IsReadOnly="True"
                     materialDesign:HintAssist.Hint="Результат"
                     Style="{StaticResource MaterialDesignOutlinedTextFieldTextBox}" Margin="10,0,0,0" TextChanged="TextInputFile_TextChanged" />
        </Grid>

        <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                Content="Сохранить" 
                Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                Margin="0,0,0,10"
                Height="42"
                Width="1000"
                HorizontalAlignment="Center"
                Click="SaveFile"/>

        <materialDesign:Snackbar 
            x:Name="NotificationSnackbar"
            MessageQueue="{materialDesign:MessageQueue}"
            Height="73"
            Width="506"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="{DynamicResource PrimaryHueMidBrush}"
            Foreground="{DynamicResource PrimaryHueMidForegroundBrush}"
            Grid.RowSpan="4"
            Panel.ZIndex="999">

            <materialDesign:Snackbar.ActionButtonStyle>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </materialDesign:Snackbar.ActionButtonStyle>
        </materialDesign:Snackbar>

    </Grid>
</Window>